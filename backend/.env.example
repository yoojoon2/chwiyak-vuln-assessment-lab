# 서버 설정
NODE_ENV=development
PORT=4000

# DB 접속 정보 (config 폴더는 gitignore 처리되어 별도 관리)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=

# 프론트엔드 연동
FRONTEND_BASE_URL=
FRONTEND_RESET_PATH=/frontend/pages/login&signup/reset_password.html
ALLOWED_FRONTEND_HOSTS=

# 메일 발송 (SendGrid)
SENDGRID_API_KEY=
MAIL_FROM=

# AWS S3 (상품 이미지 업로드)
AWS_REGION=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
